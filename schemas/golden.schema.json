{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "name": {
      "type": "string"
    },
    "specHash": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "properties": {
        "reset": {
          "type": "boolean"
        }
      }
    },
    "ignores": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "matchers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "path": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "uuid",
              "any",
              "regex",
              "number",
              "iso-date"
            ]
          },
          "pattern": {
            "type": "string"
          }
        },
        "required": [
          "path",
          "type"
        ]
      }
    },
    "steps": {
      "minItems": 1,
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "capture": {
            "type": "object",
            "propertyNames": {
              "type": "string"
            },
            "additionalProperties": {
              "type": "string"
            }
          },
          "rest": {
            "type": "object",
            "properties": {
              "method": {
                "type": "string",
                "enum": [
                  "GET",
                  "POST",
                  "PUT",
                  "PATCH",
                  "DELETE",
                  "HEAD",
                  "OPTIONS"
                ]
              },
              "path": {
                "type": "string"
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "query": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "body": {}
            },
            "required": [
              "method",
              "path"
            ]
          },
          "graphql": {
            "type": "object",
            "properties": {
              "query": {
                "type": "string"
              },
              "operationName": {
                "type": "string"
              },
              "variables": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {}
              }
            },
            "required": [
              "query"
            ]
          },
          "response": {
            "type": "object",
            "properties": {
              "status": {
                "type": "number"
              },
              "headers": {
                "type": "object",
                "propertyNames": {
                  "type": "string"
                },
                "additionalProperties": {
                  "type": "string"
                }
              },
              "body": {}
            },
            "required": [
              "status"
            ]
          }
        },
        "required": [
          "name",
          "response"
        ]
      }
    }
  },
  "required": [
    "name",
    "steps"
  ],
  "title": "golden-test-runner — golden scenario file"
}
